{
  "name": "@sublay/monorepo",
  "version": "7.4.0",
  "license": "Apache-2.0",
  "author": "Sublay, maintained by Yanay Tsabary",
  "description": "Sublay: Build interactive apps with social features like comments, votes, feeds, user lists, notifications, and more.",
  "keywords": [
    "sublay",
    "social",
    "comments",
    "reactions",
    "moderation",
    "reporting",
    "upvotes",
    "downvotes",
    "react",
    "react-native",
    "expo",
    "typescript"
  ],
  "bugs": {
    "url": "https://discord.com/invite/REKxnCJzPz"
  },
  "homepage": "https://sublay.io",
  "repository": {
    "type": "git",
    "url": "https://github.com/sublay-io/monorepo.git"
  },
  "private": false,
  "scripts": {
    "typecheck": "tsc --noEmit",
    "version:patch": "pnpm --filter @sublay/monorepo --filter @sublay/core --filter @sublay/expo --filter @sublay/react-js --filter @sublay/react-native version patch --no-git-tag-version --no-git-checks",
    "version:minor": "pnpm --filter @sublay/monorepo --filter @sublay/core --filter @sublay/expo --filter @sublay/react-js --filter @sublay/react-native version minor --no-git-tag-version --no-git-checks",
    "build-all": "pnpm --filter @sublay/core run build && pnpm --filter @sublay/react-js run build && pnpm --filter @sublay/react-native run build && pnpm --filter @sublay/expo run build",
    "publish-prod": "pnpm build-all && pnpm --filter @sublay/core --filter @sublay/expo --filter @sublay/react-js --filter @sublay/react-native publish --no-git-checks",
    "publish-beta": "pnpm build-all && pnpm --filter @sublay/core --filter @sublay/expo --filter @sublay/react-js --filter @sublay/react-native publish --tag beta --no-git-checks",
    "publish-prod:patch": "pnpm version:patch && pnpm publish-prod",
    "publish-prod:minor": "pnpm version:minor && pnpm publish-prod",
    "publish-beta:patch": "pnpm version:patch && pnpm publish-beta",
    "publish-beta:minor": "pnpm version:minor && pnpm publish-beta"
  },
  "devDependencies": {
    "@types/node": "^20.14.5",
    "@types/react": "^18.0.0",
    "react": "^18.0.0",
    "react-native": "^0.79.2",
    "rimraf": "^6.0.1",
    "typescript": "^5.7.3"
  }
}
